# All values are optional; the server runs with defaults and the in-process SDK bridge.
PORT="8787"
HOST="127.0.0.1"

CURSOR_API_BASE="https://api.cursor.com"
CURSOR_CLIENT_VERSION="2.6.22"
CURSOR_SDK_CLIENT_VERSION="sdk-1.0.13"

# SDK bridge subprocess (started automatically by `bun run server`; runs under
# Node because Bun's node:http2 client cannot speak the Cursor SDK's gRPC yet).
CURSOR_SDK_BRIDGE_PORT="8792"
# CURSOR_SDK_BRIDGE_RUNTIME="/path/to/node"
CURSOR_SDK_BRIDGE_TIMEOUT_MS="180000"
CURSOR_SDK_BRIDGE_RUN_TIMEOUT_MS="180000"

# Point at an external bridge instead of starting one in-process.
# CURSOR_SDK_BRIDGE_URL=""
# CURSOR_SDK_BRIDGE_TOKEN=""

# Legacy direct-backend fallback. Requires private Cursor endpoint values;
# never commit them.
# CURSOR_FORCE_LEGACY_BACKEND="1"
# CURSOR_BACKEND_BASE_URL=""
# CURSOR_CHAT_ENDPOINT=""
